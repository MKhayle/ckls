{
  "name": "wtfdig",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "check": "bun --bun svelte-kit sync && bun --bun svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun --bun svelte-kit sync && bun --bun svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "bun --bun prettier --check . && bun --bun eslint .",
    "format": "bun --bun prettier --write ."
  },
  "devDependencies": {
    "@internationalized/date": "3.8.1",
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tailwindcss/forms": "0.5.9",
    "@tailwindcss/typography": "0.5.15",
    "@types/bun": "^1.3.10",
    "@types/eslint": "^9.6.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.15.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.5",
    "svelte-preprocess-import-assets": "^1.1.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.21"
  },
  "type": "module",
  "dependencies": {
    "@icons-pack/svelte-simple-icons": "^7.1.0",
    "@lucide/svelte": "^0.577.0",
    "@tailwindcss/vite": "^4.2.1",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "svelte-bricks": "^0.3.2",
    "svelte-sonner": "^1.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  }
}
